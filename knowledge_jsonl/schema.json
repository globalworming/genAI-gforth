{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ForthKnowledgeCard",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "tokens",
    "stack_effect",
    "preconditions",
    "postconditions",
    "source_ref",
    "embedding_text",
    "links"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9._:-]+$"
    },
    "type": {
      "type": "string",
      "enum": [
        "word",
        "pattern",
        "anti_pattern",
        "chapter_claim",
        "example",
        "test_case"
      ]
    },
    "tokens": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "stack_effect": {
      "type": [
        "string",
        "null"
      ]
    },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "postconditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "locator"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "locator": {
          "type": "string"
        },
        "quote_fragment": {
          "type": "string"
        }
      }
    },
    "embedding_text": {
      "type": "string",
      "minLength": 1
    },
    "links": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
